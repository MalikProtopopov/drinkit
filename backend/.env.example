# БД: dev — SQLite; прод — PostgreSQL (стек §Р0.1)
DATABASE_URL=sqlite:///./juicy.db
# DATABASE_URL=postgresql+psycopg://grabzi:grabzi@localhost:5432/grabzi
REDIS_URL=
JWT_SECRET=change-me-in-prod-32-bytes-min

# Stripe: без ключа — mock-режим (оплата подтверждается сразу)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Вход по телефону без OTP (план §4.7). OTP включается флагом при подключении SMS.
AUTH_OTP_ENABLED=false
OTP_DEV_MODE=true
OTP_DEV_CODE=1836

# Медиа: dev — локальный MinIO (docker-compose), прод — S3/R2/Yandex (план §5.13)
# Без S3_BUCKET аплоад выключен, URL-инпуты остаются фолбэком.
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=grabzi
S3_SECRET_KEY=grabzi-minio
S3_BUCKET=grabzi-media
S3_REGION=us-east-1

# CORS: список origin'ов через запятую (CSV); '*' — разрешить все (dev)
CORS_ORIGINS=http://localhost:3000

# Postgres/MinIO для docker-compose
POSTGRES_DB=grabzi
POSTGRES_USER=grabzi
POSTGRES_PASSWORD=grabzi
MINIO_ROOT_USER=grabzi
MINIO_ROOT_PASSWORD=grabzi-minio
MINIO_BUCKET=grabzi-media
